# Required
AUTH_SECRET=            # random secret for session signing (openssl rand -hex 32)
AUTH_URL=               # public base URL, e.g. http://localhost:3000
AUTH_TRUST_HOST=1       # set to 1 when running behind a reverse proxy (nginx, Cloudflare, ngrok, etc.)
ENCRYPTION_SECRET=      # exactly 64 hex chars for AES-256 device password encryption

# Database (defaults to local SQLite dev.db when not set)
# DATABASE_PROVIDER: sqlite (default) | postgresql | mongodb
DATABASE_PROVIDER=
# SQLite:     DATABASE_URL="file:./dev.db"  (default)
# PostgreSQL: DATABASE_URL="postgresql://user:pass@host:5432/db"
# MongoDB:    DATABASE_URL="mongodb+srv://user:pass@cluster/db"
DATABASE_URL=

# MQTT (optional — falls back to HTTP polling when not set)
MQTT_BROKER_URL=        # e.g. mqtt://localhost:1883 or mqtts://broker:8883
MQTT_USERNAME=
MQTT_PASSWORD=

# Email alerts (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=
